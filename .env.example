# Kalshi API credentials (required for live/demo trading)
KALSHI_API_KEY=your_api_key_here
KALSHI_API_KEY_ID=your_key_id_here
KALSHI_ENVIRONMENT=demo

# Execution mode: "paper" (safe default) or "live"
EXECUTION_MODE=paper

# Logging
LOG_LEVEL=INFO

# Optional: external signal APIs
FRED_API_KEY=optional_for_economic_data
NEWS_API_KEY=optional_for_news_signals
